{
  "name": "texweave",
  "version": "0.1.0",
  "type": "module",
  "description": "Weave modern documentation from LaTeX packages",
  "main": "dist/index.js",
  "bin": {
    "texweave": "dist/cli.js"
  },
  "files": [
    "dist/**/*",
    "filters/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "format": "prettier --write 'src/**/*.ts'",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "latex",
    "tex",
    "dtx",
    "documentation",
    "literate-programming",
    "pandoc"
  ],
  "author": "Johan Larsson",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jolars/texweave.git"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "glob": "^13.0.0",
    "yaml": "^2.3.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^4.0.18",
    "prettier": "^3.2.4",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "preset": "conventionalcommits"
        }
      ],
      [
        "@semantic-release/release-notes-generator",
        {
          "preset": "conventionalcommits"
        }
      ],
      [
        "@semantic-release/changelog",
        {
          "changelogTitle": "# Changelog"
        }
      ],
      "@semantic-release/npm",
      [
        "@semantic-release/git",
        {
          "message": "chore(release): release ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}",
          "assets": [
            "CHANGELOG.md",
            "package.json",
            "pnpm-lock.yaml"
          ]
        }
      ],
      "@semantic-release/github"
    ]
  }
}
