{
  "name": "texweave",
  "version": "0.1.0",
  "type": "module",
  "description": "Weave modern documentation from LaTeX packages",
  "main": "dist/index.js",
  "bin": {
    "texweave": "dist/cli.js"
  },
  "files": [
    "dist/**/*",
    "filters/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write 'src/**/*.ts'"
  },
  "keywords": [
    "latex",
    "tex",
    "dtx",
    "documentation",
    "literate-programming",
    "pandoc"
  ],
  "author": "Johan Larsson",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jolars/texweave.git"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "glob": "^13.0.0",
    "yaml": "^2.3.4",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/glob": "^9.0.0",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.4",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
